<%- include('partials/header') %>

<div class="page-head"><h1>Staff</h1><div class="sub">Manage <%= user.account_type %> org staff and their assigned roles</div></div>

<% if (error) { %><div class="alert error"><%= error %></div><% } %>

<div class="two-col">
  <div class="card">
    <h2>Team</h2>
    <table>
      <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th></th></tr></thead>
      <tbody>
        <% staff.forEach(s => { %>
          <tr>
            <td><%= s.name %><% if (s.is_org_admin) { %> <span class="perm-pill">admin</span><% } %></td>
            <td><%= s.email %></td>
            <td><%= s.role_name || '—' %></td>
            <td><%= s.active ? 'Active' : 'Deactivated' %></td>
            <td>
              <% if (s.active && s.id !== user.id) { %>
                <form method="POST" action="/admin/staff/<%= s.id %>/deactivate">
                  <button class="btn outline small" type="submit">Deactivate</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>Add staff member</h2>
    <form method="POST" action="/admin/staff">
      <div class="field"><label>Name</label><input name="name" required></div>
      <div class="field"><label>Email</label><input type="email" name="email" required></div>
      <div class="field"><label>Temporary password</label><input type="text" name="password" required minlength="6"></div>
      <div class="field">
        <label>Role</label>
        <select name="role_id" required>
          <option value="">Select role…</option>
          <% roles.forEach(r => { %><option value="<%= r.id %>"><%= r.name %></option><% }) %>
        </select>
        <div class="hint">Need a different permission bundle? <a href="/admin/roles">Create a custom role →</a></div>
      </div>
      <button class="btn amber" type="submit">Create staff account</button>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
